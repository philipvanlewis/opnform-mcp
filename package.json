{
  "name": "opnform-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol (MCP) server for OpnForm — manage forms, submissions, workspaces, users and integrations from Claude and any MCP client. Runs locally via npx (stdio) or remotely over Streamable HTTP.",
  "type": "module",
  "license": "MIT",
  "author": "philipvanlewis (https://github.com/philipvanlewis)",
  "homepage": "https://github.com/philipvanlewis/opnform-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philipvanlewis/opnform-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/philipvanlewis/opnform-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "modelcontextprotocol",
    "opnform",
    "forms",
    "form-builder",
    "claude",
    "anthropic",
    "ai",
    "llm",
    "stdio",
    "streamable-http"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "opnform-mcp": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/cli.js",
    "start:http": "node dist/cli.js --http",
    "dev": "tsx watch src/cli.ts",
    "dev:http": "tsx watch src/cli.ts --http",
    "smoke": "node scripts/smoke.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.1",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
