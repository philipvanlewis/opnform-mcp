# ── OpnForm MCP server configuration ───────────────────────────────────────
# Copy to .env (never commit the real file).

# Base URL of your OpnForm REST API, no trailing slash.
#   • Self-hosted:  https://forms.example.com/api
#   • OpnForm Cloud: https://api.opnform.com   (verify in your account)
OPNFORM_API_BASE=https://forms.example.com/api

# OpnForm Personal Access Token (Settings → Access Tokens).
# Held server-side only — MCP clients never see it.
OPNFORM_API_TOKEN=replace-with-your-opnform-token

# ── HTTP transport only (remote mode: `opnform-mcp --http`) ─────────────────
# Bearer token(s) clients must send as: Authorization: Bearer <token>
# Comma-separate to allow several. Generate one with: openssl rand -hex 32
MCP_BEARER_TOKEN=replace-with-a-strong-random-token

# Bind address / port for HTTP mode (default 0.0.0.0:8080).
HOST=0.0.0.0
PORT=8080

# ── Optional identity shown to MCP clients ─────────────────────────────────
# MCP_SERVER_NAME=opnform-mcp
# MCP_SERVER_VERSION=
